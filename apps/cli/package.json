{
  "name": "@swarm/cli",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.tsx",
  "bin": {
    "swarm": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build src/index.tsx --outfile=../../dist/swarm --target=bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@swarm/bus": "workspace:*",
    "@swarm/config": "workspace:*",
    "@swarm/hub": "workspace:*",
    "@swarm/hermes": "workspace:*",
    "@swarm/orchestrator": "workspace:*",
    "@swarm/providers": "workspace:*",
    "@swarm/telemetry": "workspace:*",
    "@swarm/tools": "workspace:*",
    "@swarm/tui": "workspace:*",
    "@types/bun": "^1.3.12",
    "commander": "^12.0.0",
    "ink": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
