{
  "name": "swarm",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run apps/cli/src/index.tsx",
    "typecheck": "tsc --noEmit",
    "build:mac-arm": "bun build --compile --target=bun-darwin-arm64 apps/cli/src/index.tsx --outfile dist/pi3-mac-arm64",
    "build:mac-x64": "bun build --compile --target=bun-darwin-x64  apps/cli/src/index.tsx --outfile dist/pi3-mac-x64",
    "build:mac": "mkdir -p dist && bun run build:mac-arm && bun run build:mac-x64",
    "release": "bun run build:mac && echo 'Binaries ready in dist/'"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/react": "^19.0.0",
    "@types/node": "^20.0.0"
  }
}
